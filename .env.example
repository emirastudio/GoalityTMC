# Local Postgres runs in Docker on port 5433 (see docker-compose.yml).
# Credentials below match the docker-compose POSTGRES_* defaults.
DATABASE_URL=postgres://kingscup:kingscup_dev@localhost:5433/kingscup

JWT_SECRET=change-this-in-production
NEXT_PUBLIC_APP_URL=http://localhost:3001

# Email (Resend).
# The From: domain MUST be verified in Resend dashboard.
# Production uses the root domain (goalityfootball.com), where DKIM is set
# at resend._domainkey and DMARC is at _dmarc. The send.* subdomain has
# DNS records but is not (yet) verified in Resend — don't switch to it
# until verification is complete in the Resend dashboard.
RESEND_API_KEY=re_...
EMAIL_FROM=Goality <noreply@goalityfootball.com>
PRIVACY_EMAIL=goal@goalityfootball.com

# Stripe (optional for local dev — only needed if testing payment flows)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
