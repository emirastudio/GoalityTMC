# Local Postgres runs in Docker on port 5433 (see docker-compose.yml).
# Credentials below match the docker-compose POSTGRES_* defaults.
DATABASE_URL=postgres://kingscup:kingscup_dev@localhost:5433/kingscup

JWT_SECRET=change-this-in-production
NEXT_PUBLIC_APP_URL=http://localhost:3001

# Email (Resend).
# Production uses send.goalityfootball.com (Resend-verified subdomain pattern):
#   SPF on send.* → Resend (amazonses)
#   DKIM at resend._domainkey on root → signs d=goalityfootball.com
#   DMARC at _dmarc on root → relaxed alignment OK
RESEND_API_KEY=re_...
EMAIL_FROM=Goality <noreply@send.goalityfootball.com>
PRIVACY_EMAIL=goal@goalityfootball.com

# Stripe (optional for local dev — only needed if testing payment flows)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
