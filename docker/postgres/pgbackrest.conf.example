# pgBackRest config — REAL file lives on the server ONLY at
# /home/goality/pgbackrest/pgbackrest.conf (chmod 600), bind-mounted to
# /etc/pgbackrest/pgbackrest.conf inside the postgres container.
# This .example is committed for reference; it contains NO secrets.

[global]
repo1-type=s3
repo1-s3-endpoint=<ACCOUNT_ID>.r2.cloudflarestorage.com
repo1-s3-bucket=goalitytmc-1
repo1-s3-region=auto
repo1-s3-uri-style=path
repo1-s3-key=<R2_ACCESS_KEY_ID>
repo1-s3-key-secret=<R2_SECRET_ACCESS_KEY>
repo1-path=/pgbackrest
repo1-retention-full=4
repo1-retention-diff=14
process-max=2
log-level-console=info
log-level-file=detail
start-fast=y
archive-async=y
spool-path=/var/lib/pgbackrest

[goality]
pg1-path=/var/lib/postgresql/data
